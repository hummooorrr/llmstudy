TZ=Asia/Shanghai

# ── 模型 API 密钥 ──────────────────────────────────────────────
# 智谱（rerank / embedding / vision 仍走智谱）
ZHIPU_API_KEY=replace_with_your_zhipu_api_key
# Chat 模型 API 密钥（默认复用智谱；若用 DeepSeek / MiMo 等其他厂商则单独设）
DEEPSEEK_API_KEY=replace_with_your_chat_api_key

# ── Chat 模型（OpenAI 兼容接口）──────────────────────────────
# 切换模型只需改下面三项：
#   DeepSeek:  OPENAI_BASE_URL=https://api.deepseek.com
#   MiMo:      OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_BASE_URL=https://api.deepseek.com
PRO_RAG_CHAT_MODEL=deepseek-reasoner

# ── 其他模型 ──────────────────────────────────────────────────
PRO_RAG_EMBEDDING_MODEL=embedding-3
PRO_RAG_EMBEDDING_DIMENSIONS=2048
PRO_RAG_VECTOR_DIMENSIONS=2048
PRO_RAG_VISION_MODEL=glm-4.6v
PRO_RAG_RERANK_MODEL=rerank
PRO_RAG_RERANK_ENABLED=true
PRO_RAG_RERANK_BASE_URL=https://open.bigmodel.cn/api/paas/v4/rerank

# ── PostgreSQL（pgvector 向量库）───────────────────────────────
PG_URL=jdbc:postgresql://postgres:5432/rag_test
PG_USERNAME=pgvector
PG_PASSWORD=change_me_to_a_strong_password

# ── MySQL（对话记忆 / 会话元信息持久化）────────────────────────
MYSQL_URL=jdbc:mysql://mysql:3306/pro_rag?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pro_rag
MYSQL_USERNAME=pro_rag
MYSQL_PASSWORD=root

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_URIS=http://elasticsearch:9200

# ── 服务端口 ──────────────────────────────────────────────────
SERVER_PORT=28692

# ── 对话记忆窗口 ──────────────────────────────────────────────
# 返回给模型的最近 N 条消息；历史全量保留在 MySQL 里
PRO_RAG_CHAT_MEMORY_WINDOW=30
PRO_RAG_GENERATE_MEMORY_WINDOW=30
PRO_RAG_CHAT_MEMORY_LIST_LIMIT=200
PRO_RAG_CHAT_MEMORY_INIT_SCHEMA=true

# ── 文件存储 ──────────────────────────────────────────────────
PRO_RAG_UPLOAD_DIR=./pro-rag-files
PRO_RAG_GENERATED_DIR=./pro-rag-generated

# ── 清理调度 ──────────────────────────────────────────────────
PRO_RAG_CLEANUP_ENABLED=true
PRO_RAG_UPLOAD_RETENTION_DAYS=7
PRO_RAG_GENERATED_RETENTION_DAYS=7
PRO_RAG_CLEANUP_CRON=0 30 3 * * ?
PRO_RAG_CLEANUP_DRY_RUN=false

# ── 结构化解析开关 ────────────────────────────────────────────
# 关闭后 PDF/DOCX 不再抽表格/图片独立 chunk，节省 VL 调用成本
PRO_RAG_STRUCTURED_PARSE_ENABLED=true
# 每份文档最多抽几张图片进 VL（含扫描件整页 VL）
PRO_RAG_MAX_IMAGES_PER_DOC=20
PRO_RAG_VISION_MAX_CONCURRENCY=3

# ── 检索 / 融合 / 重排 ───────────────────────────────────────
PRO_RAG_PARENT_CONTEXT_ENABLED=true
PRO_RAG_RERANK_POOL_SIZE=24

# ── 缓存（Caffeine）──────────────────────────────────────────
PRO_RAG_CACHE_TTL_SECONDS=300
PRO_RAG_CACHE_MAX_SIZE=500
PRO_RAG_LOCATE_CACHE_TTL_SECONDS=600
PRO_RAG_LOCATE_CACHE_MAX_SIZE=200

# ── JVM ───────────────────────────────────────────────────────
JAVA_OPTS=-Xms512m -Xmx1536m
